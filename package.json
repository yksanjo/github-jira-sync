{
  "name": "github-jira-sync",
  "version": "1.0.0",
  "description": "Production-ready GitHub ↔ Jira two-way sync tool with smart mapping and resilient background workers",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "worker": "tsx src/workers/index.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "sync:init": "tsx src/cli/init.ts",
    "sync:test": "tsx src/cli/test.ts",
    "sync:run-worker": "tsx src/workers/index.ts"
  },
  "keywords": [
    "github",
    "jira",
    "sync",
    "integration",
    "webhook",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@prisma/client": "^5.7.1",
    "@octokit/rest": "^20.0.2",
    "bullmq": "^5.1.9",
    "dotenv": "^16.3.1",
    "fastify": "^4.24.3",
    "ioredis": "^5.3.2",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "zod": "^3.22.4",
    "yaml": "^2.3.4",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.56.0",
    "prisma": "^5.7.1",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "bin": {
    "sync": "./dist/cli/index.js"
  }
}

